# Outreach OAuth2 Credentials
# Get these from https://developers.outreach.io

OUTREACH_CLIENT_ID=your_client_id_here
OUTREACH_CLIENT_SECRET=your_client_secret_here

# IMPORTANT: Outreach requires HTTPS redirect URIs
# Option 1: Use ngrok (run: ngrok http 3000)
OUTREACH_REDIRECT_URI=https://your-ngrok-id.ngrok-free.app/callback

# After running `npm run auth`, paste your tokens here:
OUTREACH_ACCESS_TOKEN=
OUTREACH_REFRESH_TOKEN=
