{
  "description": "GTM plugin hooks — figma-console-mcp orphan cleanup on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/cleanup-figma-mcp.sh"
          }
        ]
      }
    ]
  }
}
